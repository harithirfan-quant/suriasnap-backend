# ── SuriaSnap Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Tesseract ─────────────────────────────────────────────────────────────────
# Path to the tesseract binary.
# macOS (Homebrew):  /opt/homebrew/bin/tesseract
# Linux / Docker:    /usr/bin/tesseract
TESSERACT_CMD=/usr/bin/tesseract

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Development defaults are already baked in if this var is unset.
# Production: add your Vercel deployment URL (no trailing slash).
#
# Example:
#   ALLOWED_ORIGINS=http://localhost:5173,https://suriasnap.vercel.app,https://suriasnap.my
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
# Port uvicorn listens on. Render sets this automatically in production.
PORT=8000

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# All four come from the Meta App dashboard → WhatsApp → API Setup.
#
# A token YOU invent. Paste the SAME value into Meta's webhook config so the
# GET verification handshake matches. Any random string is fine.
WHATSAPP_VERIFY_TOKEN=choose-any-random-string
# App Secret from Meta App dashboard → Settings → Basic. Verifies the
# X-Hub-Signature-256 header on every inbound POST so forged webhook
# requests are rejected. Unset = verification skipped (dev only, unsafe
# in production).
WHATSAPP_APP_SECRET=
# Temp token from API Setup (24h) or a permanent System User token for prod.
WHATSAPP_ACCESS_TOKEN=
# The test/sender phone number ID shown on the API Setup page (NOT the number).
WHATSAPP_PHONE_NUMBER_ID=
# Graph API version. Default is fine; bump only if Meta deprecates it.
WHATSAPP_API_VERSION=v21.0
# Set true to LOG outbound replies instead of calling Meta — local testing
# without a token. Leave unset/false in production.
WHATSAPP_DRY_RUN=false

# ── WhatsApp conversation storage ──────────────────────────────────────────────
# Local dev: leave DATABASE_URL unset and SQLite is used automatically
# (fine here, but ephemeral on Render's free tier — resets on every
# deploy/sleep-wake). Production: set DATABASE_URL to a free Neon or
# Supabase Postgres connection string and the backend switches over
# automatically, no other change needed.
DATABASE_URL=
SQLITE_DB_PATH=suriasnap.db
MEDIA_DIR=media
# How many days to keep message logs / bill-extraction records before they're
# purged on startup (matches our Privacy Notice's retention promise).
RETENTION_DAYS=30
# Max free-text Claude Haiku questions per WhatsApp number per rolling 24h.
# FAQ menu, greeting, and bill scan are unaffected — always free.
ASSISTANT_DAILY_CAP=20

# ── Claude Vision (primary bill OCR) ──────────────────────────────────────────
# When set, bills are read by Claude Vision (fast + accurate, ~1-2 sen/scan).
# If unset, the backend falls back to local Tesseract OCR automatically.
ANTHROPIC_API_KEY=
