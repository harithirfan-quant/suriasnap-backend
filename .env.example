# ── SuriaSnap Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Tesseract ─────────────────────────────────────────────────────────────────
# Path to the tesseract binary.
# macOS (Homebrew):  /opt/homebrew/bin/tesseract
# Linux / Docker:    /usr/bin/tesseract
TESSERACT_CMD=/usr/bin/tesseract

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Development defaults are already baked in if this var is unset.
# Production: add your Vercel deployment URL (no trailing slash).
#
# Example:
#   ALLOWED_ORIGINS=http://localhost:5173,https://suriasnap.vercel.app,https://suriasnap.my
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
# Port uvicorn listens on. Render sets this automatically in production.
PORT=8000

# Uvicorn log level: debug | info | warning | error | critical
LOG_LEVEL=info
